            "content": "⏳ **Edit** — /repo/a.ts",
            "tag": "markdown",
          },
          "vertical_align": "center",
        },
        "padding": "8px 8px 8px 8px",
        "tag": "collapsible_panel",
        "vertical_spacing": "8px",
      },
      {
